# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-50-char-random-string
DJANGO_SETTINGS_MODULE=config.settings.dev

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
DB_NAME=everfresh
DB_USER=everfresh
DB_PASSWORD=everfresh
DB_HOST=localhost
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Celery (defaults to the same Redis instance) ──────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Media & Static ─────────────────────────────────────────────────────────────
# Absolute filesystem path where uploaded files are stored.
# In dev this defaults to <BASE_DIR>/media/ — set only if you need a custom path.
MEDIA_ROOT=

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the React dev server.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Production only (leave blank in dev) ──────────────────────────────────────
# Comma-separated list of public hostnames Django will serve.
ALLOWED_HOSTS=
# Sentry DSN — leave blank to disable error reporting.
SENTRY_DSN=
